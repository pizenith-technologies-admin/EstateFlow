# Backend: from repo root run `npm run dev` (and Docker Postgres if you use it).

# Leave EXPO_PUBLIC_API_URL unset for automatic dev URLs:
#   - Expo Web, iOS Simulator → http://127.0.0.1:5000
#   - Android Emulator → http://10.0.2.2:5000

# Physical phone on same Wi‑Fi (Expo Go / dev client) — required:
# EXPO_PUBLIC_API_URL=http://YOUR_PC_LAN_IP:5000
