# ============================================================
# EstateFlow — Environment Variables
# Copy this file to .env and fill in your values.
# All variables below are required in production (Vercel).
# ============================================================

# ── Database ─────────────────────────────────────────────────
# Neon serverless PostgreSQL connection string.
# Get it from: https://console.neon.tech → your project → Connection Details
# Local Docker (see docker-compose.yml): postgresql://estateflow:estateflow@localhost:5432/estateflow
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Force DB driver: unset = auto (Neon cloud URL → serverless driver; otherwise node-postgres).
# USE_PG_DRIVER=true|false

# ── Authentication ────────────────────────────────────────────
# Strong random strings (min 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
SESSION_SECRET=replace-with-a-different-long-random-string

# ── Application ───────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ── Email — SendGrid ──────────────────────────────────────────
# Get from: https://app.sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Maps — Google Maps ────────────────────────────────────────
# VITE_ prefix = embedded in the frontend bundle at build time.
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_MAPS_API_KEY=AIzaSy_your_key_here

# ── Image Uploads — Cloudinary ────────────────────────────────
# Get from: https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── File Storage — Google Cloud Storage ───────────────────────
# Only required if using GCS for file storage (objectStorage.ts).
# GCP project ID — get from: https://console.cloud.google.com
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id

# GCS service account credentials as a base64-encoded JSON key file.
# Vercel has no filesystem, so the key must be stored inline as an env var.
# Steps:
#   1. Create a service account in GCP with Storage Object Admin role
#   2. Download the JSON key file
#   3. Base64-encode it: (Linux/Mac) base64 -i keyfile.json
#                        (Windows)   [Convert]::ToBase64String([IO.File]::ReadAllBytes("keyfile.json"))
#   4. Paste the output below (single line, no newlines)
GOOGLE_CLOUD_KEY_BASE64=base64encodedJsonKeyFileHere

# GCS bucket name used by the object storage service.
PRIVATE_OBJECT_DIR=/your-bucket-name/objects

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of additional allowed origins in production.
# *.vercel.app is always allowed automatically.
# Example: https://estateflow.com,https://www.estateflow.com
ALLOWED_ORIGINS=https://your-custom-domain.com

# ── Docker Compose (optional) ─────────────────────────────────
# docker compose reads JWT_SECRET / SESSION_SECRET / EXPO_PUBLIC_API_URL from the environment or a .env file beside docker-compose.yml.
# EXPO_PUBLIC_API_URL=http://localhost:5000
